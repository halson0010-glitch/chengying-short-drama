{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build:shared && npm run build:api",
  "builds": [
    {
      "src": "apps/api/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/api/index.ts"
    },
    {
      "src": "/health",
      "dest": "apps/api/api/index.ts"
    }
  ]
}
