generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Drama {
  id             String    @id @default(cuid())
  title          String
  subtitle       String?
  description    String
  totalEpisodes  Int       @default(1)
  category       String
  background     String
  theme          String
  audience       String
  tags           String
  setting        String
  cast           String
  posterUrl      String?
  coverUrl       String?
  featured       Boolean   @default(false)
  featuredOrder  Int?
  visualTone     String?
  aiPosterPrompt String?
  aiHeroPrompt   String?
  heat           String    @default("0万")
  status         String    @default("draft")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  episodes       Episode[]

  @@index([status])
  @@index([category])
  @@index([theme])
  @@index([background])
  @@index([featured])
  @@index([featuredOrder])
  @@index([createdAt])
  @@index([updatedAt])
}

model Episode {
  id        String   @id @default(cuid())
  dramaId   String
  episode   Int
  title     String?
  videoUrl  String?
  hlsUrl    String?
  duration  Int?
  isFree    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drama     Drama    @relation(fields: [dramaId], references: [id], onDelete: Cascade)

  @@unique([dramaId, episode])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  event       String
  anonymousId String?
  sessionId   String?
  path        String?
  device      String?
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([event])
  @@index([anonymousId])
  @@index([sessionId])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  status             String              @default("active")
  emailVerifiedAt    DateTime?
  lastLoginAt        DateTime?
  failedLoginCount   Int                 @default(0)
  lockUntil          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  payments           PaymentRecord[]
  entitlements       UserEntitlement[]

  @@index([email])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PaymentRecord {
  id                    String            @id @default(cuid())
  userId                String?
  provider              String
  amount                Int
  currency              String            @default("cny")
  status                String            @default("created")
  providerSessionId     String?
  providerPaymentId     String?
  paidAt                DateTime?
  failedAt              DateTime?
  canceledAt            DateTime?
  paymentMethod         String?
  providerCustomerEmail String?
  providerCustomerId    String?
  providerPaymentStatus String?
  failureCode           String?
  failureMessage        String?
  checkoutUrl           String?
  rawWebhookEventId     String?
  rawWebhookType        String?
  metadataJson          String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  events                PaymentEvent[]
  entitlements          UserEntitlement[]

  @@index([userId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model PaymentEvent {
  id              String         @id @default(cuid())
  paymentRecordId String?
  provider        String
  eventType       String
  eventId         String?
  status          String?
  payloadJson     String?
  createdAt       DateTime       @default(now())
  paymentRecord   PaymentRecord? @relation(fields: [paymentRecordId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([paymentRecordId])
  @@index([eventType])
  @@index([createdAt])
}

model UserEntitlement {
  id              String         @id @default(cuid())
  userId          String
  type            String
  status          String         @default("active")
  startsAt        DateTime
  endsAt          DateTime
  sourcePaymentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePayment   PaymentRecord? @relation(fields: [sourcePaymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([sourcePaymentId])
  @@index([endsAt])
}
